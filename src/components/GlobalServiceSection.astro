---
import type { SiteContent } from '../lib/types';

const { content } = Astro.props as { content: SiteContent };
---

<section class="section">
  <div class="container section-split">
    <div class="map-card" aria-hidden="true">
      <svg class="map-card__svg" viewBox="0 0 800 420" role="presentation">
        <defs>
          <linearGradient id="map-line-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#e85d04" />
            <stop offset="100%" stop-color="#0066cc" />
          </linearGradient>
          <filter id="map-route-glow" x="-20%" y="-20%" width="140%" height="140%">
            <feGaussianBlur stdDeviation="5" result="blur" />
            <feMerge>
              <feMergeNode in="blur" />
              <feMergeNode in="SourceGraphic" />
            </feMerge>
          </filter>
        </defs>
        <g class="map-card__landmasses">
          <path d="M64 110l34-25 52-17 77 1 48 18 32 33-7 22-25 10-31 23-25 41-29 7-18 24-31 4-31-21-22-34-7-39 7-22 16-25z" />
          <path d="M232 255l28-5 34 13 23 40 4 34-18 31-34 20-29-8-16-37 2-43-11-24z" />
          <path d="M354 105l32-16 40 4 23 17 26 4 21 21-6 14-41 8-16 16 10 19-7 14-31 4-22-11-15-31 4-25-18-18z" />
          <path d="M423 220l31-13 25 10 22 28 8 45-6 41-20 37-28 16-26-10-18-34-5-47 8-32-12-22z" />
          <path d="M490 86l43-17 67-3 82 12 52 18 40 32 4 25-26 10-42-8-36 7-18 12-6 18 9 16 34 7 30 12 19 27-4 29-21 15-40 3-36 15-20 26-32 22-40-1-25-13-26 8-17-20-31-20-13-30 9-26 22-28 13-34-7-24 9-24-14-28z" />
          <path d="M683 303l26-6 39 10 21 26-5 24-30 16-42-6-20-23-3-24z" />
        </g>
        <path class="map-card__route-glow" d="M483 188C510 156 548 143 590 148" />
        <path class="map-card__route" d="M483 188C510 156 548 143 590 148" />
        <circle class="map-card__dot map-card__dot--dubai" cx="483" cy="188" r="7" />
        <circle class="map-card__dot map-card__dot--china" cx="590" cy="148" r="7" />
      </svg>
      <div class="map-card__marker map-card__marker--dubai" data-i18n="ui.dubaiMarker">{content.ui.dubaiMarker}</div>
      <div class="map-card__marker map-card__marker--china" data-i18n="ui.chinaMarker">{content.ui.chinaMarker}</div>
    </div>
    <div class="section-heading section-heading--compact">
      <p class="eyebrow" data-i18n="globalServiceIntro.eyebrow">{content.globalServiceIntro.eyebrow}</p>
      <h2 data-i18n="globalServiceIntro.title">{content.globalServiceIntro.title}</h2>
      <p data-i18n="globalServiceIntro.description">{content.globalServiceIntro.description}</p>
      <ul class="bullet-list bullet-list--spaced">
        {content.globalServicePoints.map((item, index) => (
          <li data-i18n={`globalServicePoints.${index}`}>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
