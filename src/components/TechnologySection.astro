---
import type { SiteContent } from '../lib/types';

const { content } = Astro.props as { content: SiteContent };
---

<section class="section technology-section" id="technology">
  <div class="container section-split">
    <div class="section-heading section-heading--compact section-heading--light technology-section__intro">
      <p class="eyebrow" data-i18n="technologyIntro.eyebrow">{content.technologyIntro.eyebrow}</p>
      <h2 data-i18n="technologyIntro.title">{content.technologyIntro.title}</h2>
      <p data-i18n="technologyIntro.description">{content.technologyIntro.description}</p>
    </div>
    <div class="technology-section__panel">
      <ul class="bullet-list">
        {content.technologyPoints.map((item, index) => (
          <li data-i18n={`technologyPoints.${index}`}>{item}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
